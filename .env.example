# Transport Victoria Open Data GTFS-Realtime API key (server-side only).
# Get one at https://opendata.transport.vic.gov.au/ — never commit the real key.
GTFS_API_KEY=your-transport-victoria-key-here

# Admin login for /admin (news editor). Server-side only.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
# Random 32+ char string used to sign the session cookie.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string

# Vercel Blob storage token (auto-injected by Vercel when Blob is enabled).
# Locally: copy from `vercel env pull`.
BLOB_READ_WRITE_TOKEN=
